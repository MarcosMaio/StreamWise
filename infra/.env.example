# StreamWise local development environment
# Copy to infra/.env and fill in secrets

DATABASE_URL=postgresql+asyncpg://streamwise:streamwise@postgres:5432/streamwise
TMDB_API_KEY=your_tmdb_api_key_here
JWT_SECRET=change-me-in-production
MODEL_PATH=ml/artifacts/two_tower/v1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ADMIN_API_KEY=dev-admin-token

# Host ports (optional overrides)
API_PORT=8000
WEB_PORT=3000
POSTGRES_PORT=5432

# Optional OAuth (P0 optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# P1 admin dashboard (optional)
ADMIN_API_KEY=dev-admin-token

# Recommendation tuning
MMR_LAMBDA=0.7

# P2 Trakt OAuth stub (optional)
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://localhost:3000/profile/import

# P2 weekly email digest (optional — scheduler skips when SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=streamwise@localhost
SMTP_USE_TLS=true

# PostgreSQL (docker-compose)
POSTGRES_USER=streamwise
POSTGRES_PASSWORD=streamwise
POSTGRES_DB=streamwise
